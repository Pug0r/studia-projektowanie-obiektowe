#!/usr/bin/env php
<?php

use App\Kernel;
use Symfony\Bundle\FrameworkBundle\Console\Application;
use Symfony\Component\Console\Input\ArgvInput;
use Symfony\Component\ErrorHandler\Debug;

if (!in_array(PHP_SAPI, ['cli', 'phpdbg', 'embed'])) {
    echo 'Warning: The console should be invoked via the CLI version of PHP, not the '.PHP_SAPI.' SAPI'.PHP_EOL;
}

set_time_limit(0);

require dirname(__DIR__).'/vendor/autoload.php';

if (!class_exists(Application::class)) {
    throw new LogicException('You need to add "symfony/framework-bundle" as a dependency via composer.');
}

$input = new ArgvInput();
if (null !== $env = $input->getParameterOption(['--env', '-e'])) {
    putenv('APP_ENV='.$_SERVER['APP_ENV'] = $_env = $env);
} else {
    $_env = $_SERVER['APP_ENV'] ?? 'dev';
}

if ($input->hasParameterOption('--no-debug', true)) {
    putenv('APP_DEBUG='.$_SERVER['APP_DEBUG'] = '0');
}

require dirname(__DIR__).'/config/bootstrap.php';

$kernel = new Kernel($_env, (bool) ($_SERVER['APP_DEBUG'] ?? ('prod' !== $_env)));
$application = new Application($kernel);
$application->run($input);